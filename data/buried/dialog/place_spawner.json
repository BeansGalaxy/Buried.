{
    "type": "minecraft:confirmation",
    "title": "Create a Resource Spawner",
    "inputs": [
        {
            "type": "minecraft:text",
            "key": "item",
            "label": "Item",
            "label_visible": true
        },
        {
            "type": "minecraft:number_range",
            "key": "count",
            "label": "Numbers of Items",
            "start": 1,
            "end": 64,
            "step": 1,
            "initial": 1
        },
        {
            "type": "minecraft:number_range",
            "key": "speed_ticks",
            "label": "Ticks of Delay",
            "start": 1,
            "end": 20,
            "step": 1,
            "initial": 8
        },
        {
            "type": "minecraft:number_range",
            "key": "speed_seconds",
            "label": "Seconds of Delay",
            "start": 0,
            "end": 59,
            "step": 1,
            "initial": 0
        },
        {
            "type": "minecraft:number_range",
            "key": "warm_up_ticks",
            "label": "Ticks to Warm Up",
            "start": 1,
            "end": 20,
            "step": 1,
            "initial": 8
        },
        {
            "type": "minecraft:number_range",
            "key": "warm_up_seconds",
            "label": "Seconds to Warm Up",
            "start": 0,
            "end": 59,
            "step": 1,
            "initial": 0
        },
        {
            "type": "minecraft:number_range",
            "key": "range",
            "label": "Spawner Range",
            "start": 1,
            "end": 64,
            "step": 1,
            "initial": 4
        }
    ],
    "can_close_with_escape": true,
    "pause": true,
    "after_action": "close",
    "yes": {
        "label": "Create",
        "width": 80,
        "action": {
            "type": "minecraft:dynamic/run_command",
            "template": "function buried:resource_spawner/dialog {speed_ticks:$(speed_ticks),speed_seconds:$(speed_seconds),warm_up_ticks:$(warm_up_ticks),warm_up_seconds:$(warm_up_seconds),range:$(range),item:$(item),count:$(count)}"
        }
    },
    "no": {
        "label": "Cancel",
        "width": 80
    }
}